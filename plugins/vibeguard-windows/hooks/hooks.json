{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/bin/vibeguard.ps1\" claude-hook session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/bin/vibeguard.ps1\" claude-hook user-prompt"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "& \"${CLAUDE_PLUGIN_ROOT}/bin/vibeguard.ps1\" claude-hook before-tool-use"
          }
        ]
      }
    ]
  }
}
